@page
@model WebClient.Pages.BackOffice.Customers.IndexModel
@{
    ViewData["Title"] = "Quản Lý Khách Hàng";
    Layout = "_AdminLayout"; // Nhớ trỏ đúng Layout Admin của bạn!
}

<div class="container-fluid py-4">
    <div class="row justify-content-between align-items-center mb-4 g-3">
        <div class="col-auto">
            <h3 class="fw-extrabold text-dark mb-0">
                <i class="bi bi-person-lines-fill text-primary me-2"></i>TỆP KHÁCH HÀNG THÂN THIẾT
            </h3>
            <p class="text-muted small mb-0">Tra cứu thông tin liên hệ, hỗ trợ tài khoản và tra cứu địa chỉ giao hàng</p>
        </div>

        <div class="col-md-5 col-12">
            <form method="get" class="d-flex shadow-sm rounded-pill overflow-hidden bg-white border">
                <span class="input-group-text bg-transparent border-0 ps-3 text-muted"><i class="bi bi-search"></i></span>
                <input type="text" asp-for="SearchTerm" class="form-control border-0 ps-2 shadow-none fw-medium" placeholder="Tìm theo Tên hoặc SĐT (OData Filter)..." />
                <button type="submit" class="btn btn-primary px-4 fw-bold">Tìm kiếm</button>
                @if (!string.IsNullOrEmpty(Model.SearchTerm))
                {
                    <a href="/BackOffice/Customers" class="btn btn-light px-3 border-start d-flex align-items-center" title="Xóa lọc"><i class="bi bi-x-lg"></i></a>
                }
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary small fw-bold text-uppercase tracking-wider">
                        <tr>
                            <th class="ps-4 text-center" style="width: 80px;">ID</th>
                            <th>Khách hàng</th>
                            <th>Thông tin liên hệ</th>
                            <th>Địa chỉ nhận hàng</th>
                            <th class="text-center" style="width: 140px;">Trạng thái</th>
                            <th class="text-end pe-4" style="width: 140px;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Customers.Count == 0)
                        {
                            <tr><td colspan="6" class="text-center py-5 text-muted">Không tìm thấy khách hàng nào trong cơ sở dữ liệu.</td></tr>
                        }
                        @foreach (var c in Model.Customers)
                        {
                            <tr>
                                <td class="ps-4 text-center fw-bold text-secondary">#@c.CustomerId</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary-subtle text-primary fw-bolder rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 42px; height: 42px;">
                                            @(string.IsNullOrEmpty(c.FullName) ? "C" : c.FullName.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-bold text-dark">@c.FullName</h6>
                                            <span class="text-muted small">@c.Username</span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small text-dark"><i class="bi bi-envelope-at-fill text-secondary me-1"></i> @c.Email</div>
                                    <div class="small fw-semibold text-success"><i class="bi bi-telephone-fill me-1"></i> @(c.Phone ?? "<em class='text - muted fw - normal'>Chưa cung cấp</em>")</div>
                                </td>
                                <td class="text-muted small">
                                    <i class="bi bi-geo-alt-fill text-danger me-1"></i>@(c.Address ?? "Chưa cập nhật địa chỉ giao hàng mặc định")
                                </td>
                                <td class="text-center">
                                    @if (c.IsActive == true)
                                    {
                                        <span class="badge bg-success-subtle text-success fw-bold px-3 py-2 rounded-pill"><i class="bi bi-check-circle-fill me-1"></i> Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger fw-bold px-3 py-2 rounded-pill"><i class="bi bi-lock-fill me-1"></i> Đã khóa</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-primary fw-medium px-3" onclick="viewCustomerHistory(@c.CustomerId, '@c.FullName')">
                                        <i class="bi bi-clock-history me-1"></i> Lịch sử
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white py-3 small text-muted d-flex justify-content-between align-items-center px-4">
            <span>Hệ thống quản trị tệp khách hàng trung tâm</span>
            <span>Tổng số: <strong class="text-dark fw-bold">@Model.Customers.Count</strong> khách hàng</span>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function viewCustomerHistory(id, name) {
            Swal.fire({
                title: `Lịch sử mua hàng`,
                html: `Đang tra cứu các đơn hàng đã đặt của khách <strong>${name}</strong>...<br/><br/><em class="text-muted small">Tính năng do Member 3 (Order Module) gánh vác.</em>`,
                icon: 'info',
                confirmButtonText: 'Đóng'
            });
        }
    </script>
}