@page
@model WebClient.Pages.Auth.AccessDeniedModel
@{
    ViewData["Title"] = "Từ chối truy cập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="height: 100vh;">
    <div class="text-center">
        <h1 class="display-1 fw-bold text-danger">403</h1>
        <h3 class="mb-3">Bạn không có quyền truy cập!</h3>
        <p class="text-muted mb-4">Tài khoản của bạn không được cấp phép để xem trang này.</p>
        <a href="javascript:history.back()" class="btn btn-outline-secondary me-2">Quay lại trang trước</a>
        <a href="/Storefront/Index" class="btn btn-primary">Về Trang chủ</a>
    </div>
</body>
</html>