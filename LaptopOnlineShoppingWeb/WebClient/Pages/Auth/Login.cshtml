@page
@model WebClient.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Đăng nhập hệ thống - LaptopShop";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
        body {
            background-color: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            padding: 2.5rem;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
            background-color: white;
            border: 1px solid #edf2f7;
        }

        .btn-google {
            border: 1px solid #e2e8f0;
            background-color: white;
            color: #4a5568;
            font-weight: 500;
            transition: all 0.2s;
        }

            .btn-google:hover {
                background-color: #f7fafc;
                border-color: #cbd5e0;
            }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <div class="bg-dark text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                <i class="fa-solid fa-laptop-code fs-3"></i>
            </div>
            <h3 class="fw-bold text-dark">Hệ Thống Nội Bộ</h3>
            <p class="text-muted small">Vui lòng đăng nhập để tiếp tục</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger text-center small py-2 border-0 bg-danger text-white rounded-3" role="alert">
                <i class="fa-solid fa-triangle-exclamation me-1"></i> @Model.ErrorMessage
            </div>
        }

        <form method="post" action="">
            <input type="hidden" id="ReturnUrl" name="ReturnUrl" value="@Model.ReturnUrl" />

            <div class="mb-3">
                <label for="Username" class="form-label small fw-bold text-secondary text-uppercase">Tên đăng nhập</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-user text-muted"></i></span>
                    <input type="text" id="Username" name="Username" class="form-control form-control-lg border-start-0 ps-0" placeholder="admin / staff..." required />
                </div>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label for="Password" class="form-label small fw-bold text-secondary text-uppercase mb-0">Mật khẩu</label>
                    <a href="/Auth/ForgotPassword" class="text-decoration-none small text-primary fw-semibold">Quên mật khẩu?</a>
                </div>
                <div class="input-group mt-2">
                    <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-lock text-muted"></i></span>
                    <input type="password" id="Password" name="Password" class="form-control form-control-lg border-start-0 ps-0" placeholder="••••••••" required />
                </div>
            </div>

            <button type="submit" class="btn btn-dark w-100 btn-lg fw-bold mb-3 shadow-sm">ĐĂNG NHẬP</button>

            <div class="position-relative my-4">
                <hr class="text-muted border-secondary" />
                <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 small text-muted">HOẶC</span>
            </div>

            <div id="g_id_onload"
                 data-client_id="@Model.GoogleClientId"
                 data-callback="handleCredentialResponse"
                 data-auto_prompt="false">
            </div>

            <button type="button" onclick="google.accounts.id.prompt()" class="btn btn-google w-100 btn-lg d-flex align-items-center justify-content-center">
                <img src="https://www.svgrepo.com/show/475656/google-color.svg" style="width: 20px;" class="me-2" alt="Google" />
                Đăng nhập bằng Google
            </button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function handleCredentialResponse(response) {
            // Gửi token lên Backend của bạn
            fetch('https://localhost:7136/api/auth/staff-google-login', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ idToken: response.credential })
            })
            .then(res => {
                if (!res.ok) return res.json().then(err => { throw new Error(err.message); });
                return res.json();
            })
            .then(data => {
                // Lưu token vào localStorage để Dashboard dùng
                localStorage.setItem("token", data.token);
                // Redirect vào trang chính sau khi login xong
                window.location.href = "/admin/dashboard";
            })
            .catch(err => {
                Swal.fire("Đăng nhập Google thất bại", err.message, "error");
            });
        }
    </script>
</body>
</html>