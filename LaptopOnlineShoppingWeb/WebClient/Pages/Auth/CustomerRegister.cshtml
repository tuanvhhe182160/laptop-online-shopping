@page
@model WebClient.Pages.Auth.CustomerRegisterModel
@{
    ViewData["Title"] = "Đăng ký tài khoản Khách hàng";
    Layout = "_Layout"; // Dùng layout chung của Storefront do Member 3 thiết kế sau
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    <h3 class="text-center mb-4">Đăng ký thành viên</h3>

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">@Model.ErrorMessage</div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label">Họ và Tên</label>
                            <input type="text" asp-for="FullName" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" asp-for="Email" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Tên đăng nhập</label>
                            <input type="text" asp-for="Username" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu</label>
                            <input type="password" asp-for="Password" class="form-control" required minlength="6" />
                        </div>
                        <button type="submit" class="btn btn-dark w-100">Đăng ký ngay</button>
                    </form>

                    <div class="text-center mt-3">
                        <span class="text-muted">Đã có tài khoản?</span>
                        <a href="/Auth/CustomerLogin">Đăng nhập</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>