@using System.Security.Claims
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var apiBaseUrl = Configuration["ApiSettings:BaseUrl"]?.TrimEnd('/') ?? "";
    var accessToken = User.FindFirst("AccessToken")?.Value ?? "";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "";
    var fullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Tài khoản";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LaptopShop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>
<body data-api-base="@apiBaseUrl" data-token="@accessToken">
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3 py-2">
            <div class="container">
                <a class="navbar-brand fw-extrabold text-primary tracking-tight" asp-area="" asp-page="/Storefront/Index">
                    <i class="bi bi-laptop"></i> LAPTOP<span class="text-dark">SHOP</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0 fw-medium">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-page="/Storefront/Index"><i class="bi bi-shop me-1"></i> Cửa hàng</a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (role == "Admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" href="/admin/dashboard"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="/admin/branches"><i class="bi bi-buildings me-1"></i> Chi nhánh</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" href="/admin/products"><i class="bi bi-box me-1"></i> Sản phẩm</a>
                                </li>
                            }
                            else if (role == "Staff")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-bold" href="/admin/orders"><i class="bi bi-receipt me-1"></i> Duyệt đơn hàng</a>
                                </li>
                            }
                            else if (role == "WarehouseManager")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-danger fw-bold" href="/admin/dashboard"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-primary fw-bold" href="/Admin/Orders/Index"><i class="bi bi-receipt me-1"></i> Đơn hàng</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-success fw-bold" href="/BackOffice/Warehouse/Import"><i class="bi bi-upc-scan me-1"></i> Nhập kho Seri</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto mb-2 mb-sm-0 align-items-center">
                        @if (role == "" || role == "Customer")
                        {
                            <li class="nav-item me-2">
                                <a href="/ai-suggest" class="btn btn-warning fw-bold shadow-sm rounded-pill px-4 py-2">
                                    <i class="bi bi-robot me-2"></i> Nhờ AI chọn máy giúp bạn
                                </a>
                            </li>
                            <li class="nav-item me-2">
                                <a class="nav-link position-relative btn btn-light px-3 rounded-pill border" href="/storefront/cart">
                                    <i class="bi bi-cart3 text-dark fs-5"></i>
                                    <span id="cartCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">0</span>
                                </a>
                            </li>
                        }

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (role == "Customer")
                            {
                                <li class="nav-item me-3">
                                    <a class="nav-link text-dark" href="/storefront/order-history"><i class="bi bi-clock-history me-1"></i> Đơn đã mua</a>
                                </li>
                            }

                            <li class="nav-item dropdown border-start ps-3">
                                <a class="nav-link dropdown-toggle text-dark fw-bold d-flex align-items-center" href="#" id="userDropdown" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle fs-4 text-primary me-2"></i>
                                    <span>@fullName</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                                    <li><h6 class="dropdown-header text-primary fw-bold">Vai trò: @role</h6></li>
                                    <li><a class="dropdown-item py-2" href="/auth/profile"><i class="bi bi-person-gear me-2 text-secondary"></i>Hồ sơ cá nhân</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page="/Auth/Logout" class="m-0">
                                            <button class="dropdown-item text-danger py-2 fw-bold" type="submit">
                                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link text-dark fw-medium" href="/Auth/CustomerLogin">Đăng nhập</a></li>
                            <li class="nav-item"><a class="nav-link btn btn-primary text-white btn-sm ms-2 px-3 rounded-pill" href="/Auth/CustomerRegister">Đăng ký</a></li>
                            <li class="nav-item border-start ps-3 ms-3"><a class="nav-link text-muted small" href="/Auth/Login"><i class="bi bi-shield-lock me-1"></i>Nội bộ</a></li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <style>
        .hover-white:hover { color: #fff !important; }
    </style>

    <!-- Khối 4 đặc quyền bảo đảm -->
    <div class="bg-light py-5 border-top mt-auto">
        <div class="container">
            <div class="row text-center g-4">
                <div class="col-6 col-md-3">
                    <i class="bi bi-shield-check text-primary mb-3" style="font-size: 3rem;"></i>
                    <h6 class="fw-bold mb-1">Thương hiệu đảm bảo</h6>
                    <p class="text-muted small mb-0">Nhập khẩu, bảo hành chính hãng</p>
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-arrow-repeat text-primary mb-3" style="font-size: 3rem;"></i>
                    <h6 class="fw-bold mb-1">Đổi trả dễ dàng</h6>
                    <p class="text-muted small mb-0">Theo chính sách đổi trả tại LaptopShop</p>
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-truck text-primary mb-3" style="font-size: 3rem;"></i>
                    <h6 class="fw-bold mb-1">Giao hàng tận nơi</h6>
                    <p class="text-muted small mb-0">Trên toàn quốc</p>
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-award text-primary mb-3" style="font-size: 3rem;"></i>
                    <h6 class="fw-bold mb-1">Sản phẩm chất lượng</h6>
                    <p class="text-muted small mb-0">Đảm bảo tương thích và độ bền cao</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer tối màu -->
    <footer class="py-5 text-light" style="background-color: #111419;">
        <div class="container">
            <!-- Top row -->
            <div class="row align-items-center mb-4 pb-4 border-bottom border-secondary">
                <div class="col-md-8">
                    <h5 class="fw-bold mb-1">Hệ thống LaptopShop trên toàn quốc</h5>
                    <p class="text-secondary mb-0 small">Bao gồm Cửa hàng LaptopShop, Trung tâm Điện máy, Trung tâm Laptop, Garmin Brand Store</p>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <a href="#" class="btn btn-primary rounded-pill px-4 fw-bold">Xem danh sách cửa hàng</a>
                </div>
            </div>

            <!-- 4 columns -->
            <div class="row g-4">
                <div class="col-md-3">
                    <h6 class="fw-bold text-uppercase mb-3" style="font-size: 0.9rem;">Tải ứng dụng LaptopShop</h6>
                    <div class="d-flex align-items-center">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/d/d0/QR_code_for_mobile_English_Wikipedia.svg" alt="QR Code" class="bg-white p-1 rounded me-2" style="width: 80px;">
                        <div>
                            <a href="#" class="btn btn-outline-light px-3 py-1 rounded d-flex align-items-center mb-2" style="border-color: #333;">
                                <i class="bi bi-apple fs-4 me-2"></i>
                                <div class="text-start" style="line-height: 1;">
                                    <span class="small text-secondary" style="font-size: 10px;">Tải ngay trên</span><br/>
                                    <strong>App Store</strong>
                                </div>
                            </a>
                            <a href="#" class="btn btn-outline-light px-3 py-1 rounded d-flex align-items-center" style="border-color: #333;">
                                <i class="bi bi-google-play fs-4 me-2"></i>
                                <div class="text-start" style="line-height: 1;">
                                    <span class="small text-secondary" style="font-size: 10px;">Tải ngay trên</span><br/>
                                    <strong>Google Play</strong>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <h6 class="fw-bold text-uppercase mb-3" style="font-size: 0.9rem;">Về chúng tôi</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white small">Giới thiệu về công ty</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white small">Quy chế hoạt động</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white small">Chính sách bảo mật</a></li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h6 class="fw-bold text-uppercase mb-3" style="font-size: 0.9rem;">Chính sách</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white small">Chính sách bảo hành</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white small">Chính sách đổi trả</a></li>
                        <li class="mb-2"><a href="#" class="text-secondary text-decoration-none hover-white small">Giao hàng & lắp đặt</a></li>
                    </ul>
                </div>

                <div class="col-md-3">
                    <h6 class="fw-bold text-uppercase mb-3" style="font-size: 0.9rem;">Hỗ trợ thanh toán</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <div class="bg-white text-dark px-2 py-1 rounded fw-bold small d-inline-block">VISA</div>
                        <div class="bg-white text-dark px-2 py-1 rounded fw-bold small d-inline-block">MasterCard</div>
                        <div class="bg-white text-dark px-2 py-1 rounded fw-bold small d-inline-block">JCB</div>
                        <div class="bg-white text-dark px-2 py-1 rounded fw-bold small d-inline-block">ATM</div>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-5 pt-3 border-top border-secondary text-secondary small">
                &copy; 2026 - LaptopShop System
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>

    <script>
        (function () {
            const bodyToken = document.body.getAttribute('data-token');
            if (bodyToken && localStorage.getItem('token') !== bodyToken) {
                localStorage.setItem('token', bodyToken);
            }
        })();
    </script>

    <script>
        (async function(){
            try {
                if (typeof getCartCount === 'function'){
                    const count = await getCartCount();
                    const badge = document.getElementById('cartCount');
                    if(badge) badge.innerText = count || 0;
                }
            } catch(e) {}
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>