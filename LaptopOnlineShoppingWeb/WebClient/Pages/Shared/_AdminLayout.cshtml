@using System.Security.Claims
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var apiBaseUrl = Configuration["ApiSettings:BaseUrl"]?.TrimEnd('/') ?? "";
    var accessToken = User.FindFirst("AccessToken")?.Value ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            width: 260px;
        }

            .sidebar a {
                color: #adb5bd;
                text-decoration: none;
                padding: 12px 20px;
                display: block;
                border-radius: 5px;
                margin-bottom: 5px;
                transition: 0.3s;
            }
                /* Tự động sáng nút khi ở trang đó */
                .sidebar a:hover, .sidebar a.active {
                    background-color: #0d6efd;
                    color: #fff;
                }

        .main-content {
            background-color: #f8f9fa;
        }
    </style>
</head>
<body class="bg-light" data-api-base="@apiBaseUrl" data-token="@accessToken">
    <div class="d-flex">
        <div class="sidebar p-3 shadow">
            <h4 class="text-white text-center fw-bold mt-2 mb-4"><i class="bi bi-laptop"></i> <a href="/storefront/index" class="text-white text-decoration-none">LaptopShop</a></h4>
            <hr class="text-secondary">
            <ul class="nav flex-column">
                @{
                    string GetActive(string path) => ViewContext.HttpContext.Request.Path.StartsWithSegments(path) ? "active" : "";
                }

                <li class="nav-item">
                    <a class="nav-link @GetActive("/admin/dashboard")" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="/Storefront/Index"><i class="bi bi-house-door me-2"></i> Trang chủ</a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link @GetActive("/admin/users")" href="/admin/users"><i class="bi bi-people me-2"></i> Quản lý Nhân sự</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @GetActive("/admin/branches")" href="/admin/branches"><i class="bi bi-buildings me-2"></i> Quản lý Chi nhánh</a>
                    </li>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("WarehouseManager"))
                {
                    <li class="nav-item">
                        <a class="nav-link @GetActive("/Admin/PhysicalProducts")" href="/Admin/PhysicalProducts"><i class="bi bi-box-seam me-2"></i> Quản lý Tồn Kho (Seri)</a>
                    </li>
                }
                
                <li class="nav-item">
                    <a class="nav-link @GetActive("/Admin/Categories")" href="/Admin/Categories/Index"><i class="bi bi-tags me-2"></i> Hãng sản xuất</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @GetActive("/Admin/Products")" href="/Admin/Products/Index"><i class="bi bi-pc-display me-2"></i> Sản phẩm</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @GetActive("/Admin/Orders")" href="/Admin/Orders/Index"><i class="bi bi-cart-check me-2"></i> Đơn hàng</a>
                </li>
                @if (User.IsInRole("Admin") || User.IsInRole("WarehouseManager"))
                {
                    <li class="nav-item">
                        <a class="nav-link @GetActive("/BackOffice/Warehouse")" href="/BackOffice/Warehouse/Import"><i class="bi bi-upc-scan me-2"></i> Nhập kho Seri</a>
                    </li>
                }
            </ul>
        </div>

        <div class="flex-grow-1 main-content">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4 py-3 shadow-sm">
                <div class="container-fluid">
                    <span class="navbar-text fw-semibold">
                        Xin chào, <span class="text-primary">@User.FindFirst("FullName")?.Value</span>
                        <span class="badge bg-secondary ms-1">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </span>
                    <form method="post" asp-page="/Auth/Logout" class="m-0">
                        <button class="btn btn-outline-danger btn-sm" type="submit"><i class="bi bi-box-arrow-right me-1"></i> Đăng xuất</button>
                    </form>
                </div>
            </nav>
            <div class="p-4">@RenderBody()</div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (User.Identity?.IsAuthenticated == true)
    {
        var jwtToken = User.FindFirst("AccessToken")?.Value;
        <script>
            if ("@jwtToken" && localStorage.getItem("token") !== "@jwtToken") {
                localStorage.setItem("token", "@jwtToken");
            }
        </script>
    }
</body>
</html>