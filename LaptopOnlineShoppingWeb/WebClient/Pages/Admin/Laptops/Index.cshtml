@page
@model WebClient.Pages.Admin.Laptops.IndexModel
@{
    ViewData["Title"] = "Quản lý sản phẩm Laptops";
    Layout = "_AdminLayout";
    var isAdmin = User.IsInRole("Admin");
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h1 class="fw-bold text-dark">Quản lý Laptops</h1>
            <p class="text-muted mb-0">Hệ thống quản lý thông tin sản phẩm và tình trạng kho hàng.</p>
        </div>
        <div>
            <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm" onclick="openCreateModal()">
                <i class="bi bi-plus-circle"></i> Thêm Laptop mới
            </button>
        </div>
    </div>

    <!-- Search and Filter Form -->
    <div class="card shadow-sm border-0 mb-4 rounded-3">
        <div class="card-body bg-white p-4">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="Search" class="form-label fw-semibold text-muted small">Tìm kiếm sản phẩm</label>
                    <input type="text" class="form-control rounded-pill border-secondary-subtle px-3" asp-for="Search" placeholder="Nhập tên hoặc mã laptop..." />
                </div>
                <div class="col-md-3">
                    <label for="CategoryId" class="form-label fw-semibold text-muted small">Hãng sản xuất</label>
                    <select class="form-select rounded-pill border-secondary-subtle" asp-for="CategoryId">
                        <option value="">-- Tất cả Hãng --</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="Status" class="form-label fw-semibold text-muted small">Trạng thái bán</label>
                    <select class="form-select rounded-pill border-secondary-subtle" asp-for="Status">
                        <option value="">-- Tất cả --</option>
                        <option value="true">Đang bán</option>
                        <option value="false">Ngừng bán</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="MinPrice" class="form-label fw-semibold text-muted small">Giá từ (VND)</label>
                    <input type="number" step="100000" class="form-control rounded-pill border-secondary-subtle" asp-for="MinPrice" placeholder="0" />
                </div>
                <div class="col-md-2">
                    <label for="MaxPrice" class="form-label fw-semibold text-muted small">Đến (VND)</label>
                    <input type="number" step="100000" class="form-control rounded-pill border-secondary-subtle" asp-for="MaxPrice" placeholder="Ví dụ: 30000000" />
                </div>
                <div class="col-12 d-flex justify-content-end gap-2 mt-3">
                    <a href="/Admin/Laptops/Index" class="btn btn-outline-secondary rounded-pill px-4"><i class="bi bi-x-circle"></i> Xóa lọc</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4"><i class="bi bi-funnel-fill"></i> Lọc dữ liệu</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Products Table -->
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light table-light text-secondary">
                        <tr>
                            <th class="ps-4">Hình ảnh</th>
                            <th>Mã sản phẩm</th>
                            <th>Tên Laptop</th>
                            <th>Danh mục / Hãng</th>
                            <th>Đơn giá (VND)</th>
                            <th>Số lượng</th>
                            <th>Trạng thái</th>
                            <th class="pe-4 text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Laptops != null && Model.Laptops.Count > 0)
                        {
                            foreach (var item in Model.Laptops)
                            {
                                 var fullImageUrl = (item.ImageUrl.StartsWith("http") 
                                     ? item.ImageUrl 
                                     : Model.ApiBaseUrl + item.ImageUrl) + "?t=" + DateTime.Now.Ticks;

                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center justify-content-center bg-light rounded" style="width: 60px; height: 50px; overflow: hidden;">
                                            <img src="@fullImageUrl" class="img-fluid" style="max-height: 100%; max-width: 100%; object-fit: contain;" alt="@item.LaptopName" onerror="this.onerror=null;this.src='/favicon.ico';this.style.width='25px';this.style.height='25px';" />
                                        </div>
                                    </td>
                                    <td><span class="badge bg-secondary-subtle text-secondary font-monospace">@item.LaptopCode</span></td>
                                    <td class="fw-bold text-dark">@item.LaptopName</td>
                                    <td>@item.Category?.CategoryName</td>
                                    <td class="fw-bold text-danger">@item.Price.ToString("N0") đ</td>
                                    <td>
                                        @if (item.StockQuantity <= 5)
                                        {
                                            <span class="badge bg-danger">Chỉ còn @item.StockQuantity</span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">@item.StockQuantity</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == true)
                                        {
                                            <span class="badge bg-success-subtle text-success rounded-pill px-3">Đang bán</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger rounded-pill px-3">Ngừng bán</span>
                                        }
                                    </td>
                                    <td class="pe-4 text-end">
                                        <div class="btn-group">
                                            <button class="btn btn-outline-secondary btn-sm rounded-circle me-2" style="width: 32px; height: 32px; padding: 0;" onclick="openEditModal(@item.LaptopId)" title="Chỉnh sửa">
                                                <i class="bi bi-pencil-fill" style="font-size: 13px;"></i>
                                            </button>
                                            @if (isAdmin)
                                            {
                                                <button class="btn btn-outline-danger btn-sm rounded-circle" style="width: 32px; height: 32px; padding: 0;" onclick="confirmDelete(@item.LaptopId, '@item.LaptopName')" title="Xóa">
                                                    <i class="bi bi-trash-fill" style="font-size: 13px;"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-laptop display-4 opacity-25"></i>
                                    <p class="mt-2 mb-0">Chưa có sản phẩm laptop nào trong hệ thống.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Laptop Modal (Create / Edit) -->
<div class="modal fade" id="laptopModal" tabindex="-1" aria-labelledby="laptopModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="laptopModalTitle">Thêm Laptop mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="laptopForm">
                    <input type="hidden" id="laptopId" />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="modalLaptopCode" class="form-label fw-bold small text-secondary">Mã sản phẩm (Unique Code)*</label>
                            <input type="text" class="form-control" id="modalLaptopCode" required maxlength="20" placeholder="VD: ASUS-G513" />
                        </div>
                        <div class="col-md-6">
                            <label for="modalLaptopName" class="form-label fw-bold small text-secondary">Tên sản phẩm*</label>
                            <input type="text" class="form-control" id="modalLaptopName" required maxlength="150" placeholder="VD: Asus ROG Strix G15" />
                        </div>
                        <div class="col-md-6">
                            <label for="modalCategoryId" class="form-label fw-bold small text-secondary">Hãng sản xuất / Danh mục*</label>
                            <select class="form-select" id="modalCategoryId" required>
                                <option value="">-- Chọn Hãng --</option>
                                @foreach (var cat in Model.Categories)
                                {
                                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="modalPrice" class="form-label fw-bold small text-secondary">Đơn giá (VND)*</label>
                            <input type="number" class="form-control" id="modalPrice" required min="1" placeholder="Giá > 0" />
                        </div>
                        <div class="col-md-3">
                            <label for="modalStockQuantity" class="form-label fw-bold small text-secondary">Số lượng tồn kho*</label>
                            <input type="number" class="form-control" id="modalStockQuantity" required min="1" placeholder="Số lượng > 0" />
                        </div>
                        
                        <div class="col-md-12">
                            <label for="imageFile" class="form-label fw-bold small text-secondary">Hình ảnh sản phẩm</label>
                            <div class="input-group">
                                <input type="file" class="form-control" id="imageFile" accept="image/*" />
                            </div>
                            <div class="mt-3 text-center border p-2 rounded" style="background-color: #fafafa;">
                                <img id="imagePreview" src="/favicon.ico" class="img-fluid rounded" style="max-height: 150px; display: none;" alt="Preview" />
                                <span id="previewPlaceholder" class="text-muted small">Chưa chọn ảnh sản phẩm</span>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" role="switch" id="modalStatus" checked />
                                <label class="form-check-label fw-bold small" for="modalStatus">Cho phép bán sản phẩm này</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 p-3 pt-0">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" onclick="saveLaptop()"><i class="bi bi-save"></i> Lưu thông tin</button>
            </div>
        </div>
    </div>
</div>

<!-- Icons from bootstrap CDN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

@section Scripts {
    <script>
        const token = '@Model.AccessToken';
        const apiBaseUrl = '@Model.ApiBaseUrl';
        let laptopModal;
        let isEditMode = false;

        $(document).ready(function() {
            laptopModal = new bootstrap.Modal(document.getElementById('laptopModal'));
            
            // Image preview handler
            $('#imageFile').change(function(e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        $('#imagePreview').attr('src', e.target.result).show();
                        $('#previewPlaceholder').hide();
                    }
                    reader.readAsDataURL(file);
                } else {
                    $('#imagePreview').hide();
                    $('#previewPlaceholder').show();
                }
            });
        });

        function openCreateModal() {
            isEditMode = false;
            $('#laptopModalTitle').text('Thêm Laptop mới');
            $('#laptopForm')[0].reset();
            $('#laptopId').val('');
            $('#modalLaptopCode').prop('disabled', false); // Allow entering code
            $('#imagePreview').hide();
            $('#previewPlaceholder').show();
            $('#imageFile').val('');
            laptopModal.show();
        }

        async function openEditModal(id) {
            isEditMode = true;
            $('#laptopModalTitle').text('Chỉnh sửa thông tin Laptop');
            $('#laptopForm')[0].reset();
            $('#laptopId').val(id);
            $('#modalLaptopCode').prop('disabled', true); // Do not change code to avoid naming mismatch
            $('#imageFile').val('');

            try {
                // Fetch product details
                const response = await fetch(`${apiBaseUrl}/api/Laptops/${id}`, {
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                
                if (response.ok) {
                    const item = await response.json();
                    $('#modalLaptopCode').val(item.laptopCode);
                    $('#modalLaptopName').val(item.laptopName);
                    $('#modalCategoryId').val(item.categoryId);
                    $('#modalPrice').val(item.price);
                    $('#modalStockQuantity').val(item.stockQuantity);
                    $('#modalStatus').prop('checked', item.status === true);

                    // Show image preview
                    if (item.imageUrl) {
                        const fullImg = item.imageUrl.startsWith("http") ? item.imageUrl : apiBaseUrl + item.imageUrl;
                        // Avoid caching issues
                        $('#imagePreview').attr('src', fullImg + '?t=' + new Date().getTime()).show();
                        $('#previewPlaceholder').hide();
                    } else {
                        $('#imagePreview').hide();
                        $('#previewPlaceholder').show();
                    }

                    laptopModal.show();
                } else {
                    Swal.fire('Lỗi', 'Không thể tải thông tin sản phẩm.', 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Lỗi', 'Có lỗi kết nối đến máy chủ.', 'error');
            }
        }

        async function saveLaptop() {
            // Validate form
            const form = document.getElementById('laptopForm');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const id = $('#laptopId').val();
            const laptopCode = $('#modalLaptopCode').val().trim();
            const laptopName = $('#modalLaptopName').val().trim();
            const categoryId = parseInt($('#modalCategoryId').val());
            const price = parseFloat($('#modalPrice').val());
            const stockQuantity = parseInt($('#modalStockQuantity').val());
            const status = $('#modalStatus').is(':checked');

            // Price validation
            if (price <= 0) {
                Swal.fire('Lỗi xác thực', 'Đơn giá bán phải lớn hơn 0.', 'warning');
                return;
            }

            // Stock validation
            if (stockQuantity <= 0) {
                Swal.fire('Lỗi xác thực', 'Số lượng tồn kho phải lớn hơn 0.', 'warning');
                return;
            }

            Swal.showLoading();

            try {
                // 1. Check and upload image if exists
                const imageFileInput = document.getElementById('imageFile');
                if (imageFileInput.files.length > 0) {
                    const formData = new FormData();
                    formData.append('file', imageFileInput.files[0]);

                    const uploadRes = await fetch(`${apiBaseUrl}/api/Laptops/${laptopCode}/upload-image`, {
                        method: 'POST',
                        headers: { 'Authorization': 'Bearer ' + token },
                        body: formData
                    });

                    if (!uploadRes.ok) {
                        const uploadErr = await uploadRes.json();
                        Swal.fire('Lỗi upload ảnh', uploadErr.message || 'Không thể upload hình ảnh.', 'error');
                        return;
                    }
                }

                // 2. Save product info
                let url = `${apiBaseUrl}/api/Laptops`;
                let method = 'POST';
                let payload = { laptopCode, laptopName, categoryId, price, stockQuantity, status };

                if (isEditMode) {
                    url = `${apiBaseUrl}/api/Laptops/${id}`;
                    method = 'PUT';
                }

                const response = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token
                    },
                    body: JSON.stringify(payload)
                });

                if (response.ok) {
                    laptopModal.hide();
                    Swal.fire({
                        title: 'Thành công',
                        text: isEditMode ? 'Đã cập nhật sản phẩm thành công!' : 'Đã thêm sản phẩm mới thành công!',
                        icon: 'success',
                        confirmButtonText: 'Đồng ý'
                    }).then(() => {
                        window.location.reload();
                    });
                } else {
                    const errData = await response.json();
                    Swal.fire('Lỗi', errData.message || 'Không thể lưu sản phẩm.', 'error');
                }
            } catch (err) {
                console.error(err);
                Swal.fire('Lỗi', 'Có lỗi xảy ra trong quá trình kết nối.', 'error');
            }
        }

        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Xác nhận xóa?',
                text: `Bạn có chắc chắn muốn xóa sản phẩm Laptop "${name}" không?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy bỏ'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    Swal.showLoading();
                    try {
                        const response = await fetch(`${apiBaseUrl}/api/Laptops/${id}`, {
                            method: 'DELETE',
                            headers: { 'Authorization': 'Bearer ' + token }
                        });

                        if (response.ok) {
                            const resData = await response.json();
                            if (resData.isSoftDeleted) {
                                Swal.fire({
                                    title: 'Ngừng bán (Xóa mềm)',
                                    text: 'Laptop đã từng bán trong các đơn hàng trước. Hệ thống tự động chuyển trạng thái ngừng kinh doanh thay vì xóa khỏi hệ thống.',
                                    icon: 'info',
                                    confirmButtonText: 'Đã hiểu'
                                }).then(() => {
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire('Thành công', 'Đã xóa sản phẩm khỏi hệ thống.', 'success').then(() => {
                                    window.location.reload();
                                });
                            }
                        } else {
                            const errData = await response.json();
                            Swal.fire('Lỗi', errData.message || 'Xóa sản phẩm thất bại.', 'error');
                        }
                    } catch (err) {
                        console.error(err);
                        Swal.fire('Lỗi', 'Lỗi kết nối máy chủ.', 'error');
                    }
                }
            });
        }
    </script>
}
