@page "/admin/dashboard"
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Bảng Điều Khiển Tổng Quan";
}

<div class="container-fluid py-4">
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-sm-6">
            <div class="card border-0 shadow-sm py-2" style="border-left: 4px solid #4e73df !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-primary text-uppercase mb-1">Tổng Nhân Sự</div>
                            <div class="h3 mb-0 fw-bold text-gray-800" id="kpi-users">
                                <span class="spinner-border spinner-border-sm text-primary"></span>
                            </div>
                        </div>
                        <div class="col-auto"><i class="fa-solid fa-user-tie fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card border-0 shadow-sm py-2" style="border-left: 4px solid #1cc88a !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-success text-uppercase mb-1">Khách Hàng</div>
                            <div class="h3 mb-0 fw-bold text-gray-800" id="kpi-customers">
                                <span class="spinner-border spinner-border-sm text-success"></span>
                            </div>
                        </div>
                        <div class="col-auto"><i class="fa-solid fa-users fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card border-0 shadow-sm py-2" style="border-left: 4px solid #36b9cc !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-info text-uppercase mb-1">Chi Nhánh</div>
                            <div class="h3 mb-0 fw-bold text-gray-800" id="kpi-branches">
                                <span class="spinner-border spinner-border-sm text-info"></span>
                            </div>
                        </div>
                        <div class="col-auto"><i class="fa-solid fa-store fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-sm-6">
            <div class="card border-0 shadow-sm py-2" style="border-left: 4px solid #e74a3b !important;">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col me-2">
                            <div class="text-xs fw-bold text-danger text-uppercase mb-1">Tổng Doanh Thu</div>
                            <div class="h4 mb-0 fw-bold text-gray-800" id="kpi-revenue">
                                <span class="spinner-border spinner-border-sm text-danger"></span>
                            </div>
                        </div>
                        <div class="col-auto"><i class="fa-solid fa-sack-dollar fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white fw-bold py-3">
                    <i class="fa-solid fa-chart-column text-primary me-2"></i> Tăng Trưởng Doanh Thu Theo Tháng
                </div>
                <div class="card-body">
                    <div style="height: 320px;"><canvas id="monthChart"></canvas></div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white fw-bold py-3">
                    <i class="fa-solid fa-chart-pie text-warning me-2"></i> Tỉ Trọng Theo Chi Nhánh
                </div>
                <div class="card-body d-flex flex-column justify-content-center">
                    <div style="height: 280px;"><canvas id="branchChart"></canvas></div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-bold py-3">
            <i class="fa-solid fa-trophy text-warning me-2"></i> Top 5 Mẫu Laptop Bán Chạy Nhất Toàn Quốc
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="width: 80px;">Top</th>
                            <th>Tên Sản Phẩm</th>
                            <th class="text-center" style="width: 180px;">Đã Bán</th>
                        </tr>
                    </thead>
                    <tbody id="top-products-tbody">
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">
                                <span class="spinner-border spinner-border-sm me-2"></span> Đang tải danh sách...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = "https://localhost:7136/api/dashboard";

        // Hàm lấy JWT Token từ localStorage (hoặc sessionStorage tùy bạn lưu)
        function getAuthHeader() {
            const token = localStorage.getItem("token") || sessionStorage.getItem("token");
            return {
                "Authorization": `Bearer ${token}`,
                "Content-Type": "application/json"
            };
        }

        async function loadDashboardData() {
            const headers = getAuthHeader();

            try {
                // 1. TẢI THẺ KPI
                fetch(`${API_BASE}/summary`, { headers }).then(r => r.json()).then(data => {
                    document.getElementById("kpi-users").innerText = data.totalUsers;
                    document.getElementById("kpi-customers").innerText = data.totalCustomers;
                    document.getElementById("kpi-branches").innerText = data.totalBranches;
                    document.getElementById("kpi-revenue").innerText = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(data.totalRevenue);
                });

                // 2. TẢI BIỂU ĐỒ THÁNG (BAR CHART)
                fetch(`${API_BASE}/revenue-by-month`, { headers }).then(r => r.json()).then(data => {
                    new Chart(document.getElementById("monthChart"), {
                        type: 'bar',
                        data: {
                            labels: data.map(x => x.month),
                            datasets: [{
                                label: 'Doanh thu (VNĐ)',
                                data: data.map(x => x.revenue),
                                backgroundColor: 'rgba(78, 115, 223, 0.8)',
                                hoverBackgroundColor: 'rgba(78, 115, 223, 1)',
                                borderRadius: 6
                            }]
                        },
                        options: { maintainAspectRatio: false, plugins: { legend: { display: false } } }
                    });
                });

                // 3. TẢI BIỂU ĐỒ TRÒN (DOUGHNUT CHART)
                fetch(`${API_BASE}/revenue-by-branch`, { headers }).then(r => r.json()).then(data => {
                    new Chart(document.getElementById("branchChart"), {
                        type: 'doughnut',
                        data: {
                            labels: data.map(x => x.branchName),
                            datasets: [{
                                data: data.map(x => x.revenue),
                                backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#858796']
                            }]
                        },
                        options: { maintainAspectRatio: false }
                    });
                });

                // 4. TẢI BẢNG TOP SẢN PHẨM
                fetch(`${API_BASE}/top-products`, { headers }).then(r => r.json()).then(data => {
                    const tbody = document.getElementById("top-products-tbody");
                    if (data.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="3" class="text-center py-3">Chưa có đơn hàng nào hoàn thành.</td></tr>`;
                        return;
                    }
                    tbody.innerHTML = data.map((item, index) => `
                        <tr>
                            <td class="ps-4 fw-bold text-${index === 0 ? 'danger' : index === 1 ? 'warning' : index === 2 ? 'primary' : 'muted'}">
                                #${index + 1}
                            </td>
                            <td class="fw-semibold">${item.productName}</td>
                            <td class="text-center"><span class="badge bg-success fs-6">${item.soldQuantity} chiếc</span></td>
                        </tr>
                    `).join('');
                });

            } catch (err) {
                console.error("Lỗi khi kéo dữ liệu Dashboard:", err);
            }
        }

        // Kích nổ AJAX ngay khi trình duyệt vừa vẽ xong HTML
        document.addEventListener("DOMContentLoaded", loadDashboardData);
    </script>
}