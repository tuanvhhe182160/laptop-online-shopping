@page
@model WebClient.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý Nhân sự";
    Layout = "_AdminLayout";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Danh sách Nhân sự</h3>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
            + Thêm nhân viên
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Tài khoản</th>
                        <th>Họ và Tên</th>
                        <th>Email</th>
                        <th>Quyền</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.UserId</td>
                            <td class="fw-bold">@user.Username</td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td><span class="badge bg-secondary">@user.RoleName</span></td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã khóa</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-page="./Details" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-info me-1">
                                    Chi tiết
                                </a>

                                <form method="post" asp-page-handler="Toggle" class="d-inline" onsubmit="if(this.submitted) return false; this.submitted = true; return true;">
                                    <input type="hidden" name="id" value="@user.UserId" />
                                    <button type="submit" class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")">
                                        @(user.IsActive ? "Khóa" : "Mở khóa")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="createUserModalLabel">Thêm Nhân sự mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="NewUser_Username" class="form-label">Tên đăng nhập</label>
                        <input type="text" id="NewUser_Username" name="NewUser.Username" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="NewUser_Password" class="form-label">Mật khẩu</label>
                        <input type="password" id="NewUser_Password" name="NewUser.Password" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="NewUser_FullName" class="form-label">Họ và tên</label>
                        <input type="text" id="NewUser_FullName" name="NewUser.FullName" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="NewUser_Email" class="form-label">Email</label>
                        <input type="email" id="NewUser_Email" name="NewUser.Email" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label for="NewUser_RoleId" class="form-label">Quyền hạn</label>
                        <select id="NewUser_RoleId" name="NewUser.RoleId" class="form-select" required>
                            <option value="">-- Chọn quyền --</option>
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role.RoleId">@role.RoleName</option>
                            }
                        </select>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" asp-for="NewUser.IsActive" checked />
                        <label class="form-check-label" asp-for="NewUser.IsActive">Kích hoạt tài khoản</label>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Lưu thông tin</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // ==========================================
            // 1. XỬ LÝ THÔNG BÁO TỪ BACKEND TRẢ VỀ
            // ==========================================
            var successMsg = '@Html.Raw(TempData["SuccessMessage"])';
            var errorMsg = '@Html.Raw(TempData["ErrorMessage"])';

            if (successMsg && successMsg.trim() !== '') {
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công',
                    text: successMsg,
                    timer: 2000,
                    showConfirmButton: false
                });
            }

            if (errorMsg && errorMsg.trim() !== '') {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    text: errorMsg
                });
            }

                    // ==========================================
        // 2. VŨ KHÍ CHẶN DOUBLE SUBMIT (CHUẨN 100%)
        // ==========================================
        const forms = document.querySelectorAll('form');

        forms.forEach(form => {
            form.addEventListener('submit', function (e) {
                const submitBtn = form.querySelector('button[type="submit"]');

                if (submitBtn) {
                    // Nếu nút đã bị đánh dấu là đang xử lý, chặn đứng luôn!
                    if (submitBtn.classList.contains('is-submitting')) {
                        e.preventDefault();
                        return;
                    }

                    // 1. Đánh dấu nút này đã được bấm
                    submitBtn.classList.add('is-submitting');

                    // 2. Đổi chữ thành vòng xoay loading
                    const isLocking = submitBtn.innerText.includes("Khóa") && !submitBtn.innerText.includes("Mở");
                    submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> ${isLocking ? "Đang khóa..." : "Đang mở..."}`;

                    // 3. MẸO ĐỈNH CAO: Khóa nút sau 10 mili-giây.
                    // Giúp trình duyệt vẫn kịp đóng gói và gửi form đi 1 lần duy nhất!
                    setTimeout(() => {
                        submitBtn.disabled = true;
                    }, 10);
                }
            });
        });
        });
    </script>
}