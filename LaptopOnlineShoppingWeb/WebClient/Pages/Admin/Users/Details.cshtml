@page "{id:int}"
@model WebClient.Pages.Admin.Users.DetailsModel
@{
    ViewData["Title"] = "Chi tiết Nhân sự";
    Layout = "_AdminLayout";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-primary">Thông tin Nhân sự #@Model.UserDetail.UserId</h3>
        <a asp-page="./Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="card shadow-sm border-0 col-md-6">
        <div class="card-body p-4">
            <table class="table table-borderless fs-5">
                <tbody>
                    <tr>
                        <th class="text-muted w-25">Tài khoản:</th>
                        <td class="fw-bold">@Model.UserDetail.Username</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Họ và tên:</th>
                        <td>@Model.UserDetail.FullName</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Email:</th>
                        <td>@Model.UserDetail.Email</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Quyền hạn:</th>
                        <td><span class="badge bg-primary fs-6">@Model.UserDetail.RoleName</span></td>
                    </tr>
                    <tr>
                        <th class="text-muted">Trạng thái:</th>
                        <td>
                            @if (Model.UserDetail.IsActive)
                            {
                                <span class="badge bg-success fs-6"><i class="bi bi-check-circle"></i> Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger fs-6"><i class="bi bi-lock-fill"></i> Đã bị khóa</span>
                            }
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>