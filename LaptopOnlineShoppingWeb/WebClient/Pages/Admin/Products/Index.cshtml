@page
@model WebClient.Pages.Admin.Products.IndexModel
@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "_AdminLayout";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark m-0">Quản lý Sản phẩm & Cấu hình</h3>
        <button class="btn btn-primary shadow-sm" onclick="openProductModal()">
            <i class="bi bi-plus-circle me-1"></i> Thêm Sản phẩm Mới
        </button>
    </div>

    <!-- OData Filter Toolbar -->
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Tìm kiếm Tên/Mã</label>
                    <input type="text" id="filter_search" class="form-control" placeholder="Nhập từ khóa..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Hãng sản xuất</label>
                    <select id="filter_categoryId" class="form-select">
                        <option value="">-- Tất cả Hãng --</option>
                        @foreach (var c in Model.Categories)
                        {
                            <option value="@c.CategoryId">@c.CategoryName</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Trạng thái</label>
                    <select id="filter_status" class="form-select">
                        <option value="">-- Tất cả --</option>
                        <option value="true">Đang bán</option>
                        <option value="false">Ngừng bán</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <div class="d-flex w-100 gap-2">
                        <button class="btn btn-primary flex-fill" onclick="loadProducts()">
                            <i class="bi bi-funnel"></i> Lọc
                        </button>
                        <button class="btn btn-secondary flex-fill" onclick="resetFilters()">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Grid -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle m-0" id="productsTable">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Mã SP</th>
                            <th>Tên Sản Phẩm</th>
                            <th>Hãng</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Rendered by AJAX -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Product Modal -->
<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold" id="productModalTitle">Thêm Sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <form id="productForm">
                    <input type="hidden" id="p_id" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mã Sản phẩm <span class="text-danger">*</span></label>
                        <input type="text" id="p_code" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tên Sản phẩm <span class="text-danger">*</span></label>
                        <input type="text" id="p_name" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hãng sản xuất <span class="text-danger">*</span></label>
                        <select id="p_categoryId" class="form-select" required>
                            <option value="">-- Chọn Hãng --</option>
                            @foreach (var c in Model.Categories)
                            {
                                <option value="@c.CategoryId">@c.CategoryName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Trạng thái</label>
                        <select id="p_status" class="form-select">
                            <option value="true">Đang kinh doanh</option>
                            <option value="false">Ngừng kinh doanh</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mô tả tóm tắt</label>
                        <textarea id="p_description" class="form-control" rows="3"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-success px-4" onclick="saveProduct()">Lưu lại</button>
            </div>
        </div>
    </div>
</div>

<!-- Variants Modal -->
<div class="modal fade" id="variantsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom-0 d-flex justify-content-between align-items-center">
                <h5 class="modal-title fw-bold" id="variantsModalTitle">Cấu hình biến thể</h5>
                <div>
                    <button class="btn btn-sm btn-primary me-2" onclick="openVariantFormModal()">
                        <i class="bi bi-plus"></i> Thêm Cấu hình
                    </button>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
            </div>
            <div class="modal-body p-0">
                <input type="hidden" id="currentProductIdForVariants" />
                <table class="table table-hover align-middle m-0" id="variantsTable">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">CPU</th>
                            <th>RAM</th>
                            <th>SSD</th>
                            <th>Màu sắc</th>
                            <th>Giá bán</th>
                            <th>Tồn kho</th>
                            <th class="text-end pe-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Variants by AJAX -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Variant Form Modal -->
<div class="modal fade" id="variantFormModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold" id="variantFormModalTitle">Thêm Cấu hình</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <form id="variantForm">
                    <input type="hidden" id="v_id" value="0" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">CPU</label>
                        <input type="text" id="v_cpu" class="form-control" placeholder="Core i7" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">RAM</label>
                        <input type="text" id="v_ram" class="form-control" placeholder="16GB" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">SSD</label>
                        <input type="text" id="v_ssd" class="form-control" placeholder="512GB" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Màu sắc</label>
                        <input type="text" id="v_color" class="form-control" placeholder="Đen" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                        <input type="number" id="v_price" class="form-control" min="0.01" required />
                        <div class="invalid-feedback">Giá tiền phải lớn hơn 0</div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-success px-4" onclick="saveVariant()">Lưu lại</button>
            </div>
        </div>
    </div>
</div>

<!-- Upload Image Modal -->
<div class="modal fade" id="uploadImageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-bottom-0">
                <h5 class="modal-title fw-bold">Cập nhật Ảnh Sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <form id="uploadImageForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="upload_pcode" name="productCode" />
                    <div class="mb-3 text-center">
                        <img id="upload_preview" src="" class="img-fluid rounded mb-3 shadow-sm" style="max-height: 200px;" onerror="this.src='https://fakeimg.pl/400x300/e9ecef/6c757d?text=No+Image'"/>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Vị trí ảnh</label>
                        <select class="form-select" id="upload_imageIndex" name="imageIndex" onchange="changeImagePreview()">
                            <option value="0">Ảnh chính (Đại diện)</option>
                            <option value="1">Ảnh phụ 1</option>
                            <option value="2">Ảnh phụ 2</option>
                            <option value="3">Ảnh phụ 3</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Chọn file ảnh (.jpg, .png)</label>
                        <input type="file" id="upload_file" name="imageFile" class="form-control" accept="image/png, image/jpeg" required onchange="previewImage(event)" />
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-success px-4" onclick="submitUploadImage()">Tải lên</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/40.0.0/classic/ckeditor.js"></script>
    <script>
        let apiBase = document.body.getAttribute('data-api-base') || '';
        let token = document.body.getAttribute('data-token') || '';
        
        let pModal, vModal, vfModal, uploadModal;
        let editorInstance;
        
        document.addEventListener("DOMContentLoaded", () => {
            pModal = new bootstrap.Modal(document.getElementById('productModal'));
            vModal = new bootstrap.Modal(document.getElementById('variantsModal'));
            vfModal = new bootstrap.Modal(document.getElementById('variantFormModal'));
            uploadModal = new bootstrap.Modal(document.getElementById('uploadImageModal'));
            loadProducts();

            if (typeof ClassicEditor !== 'undefined') {
                ClassicEditor
                    .create(document.querySelector('#p_description'))
                    .then(editor => {
                        editorInstance = editor;
                    })
                    .catch(error => {
                        console.error(error);
                    });
            }
        });

        const getHeaders = () => ({
            'Content-Type': 'application/json',
            'Authorization': 'Bearer ' + token
        });

        // ================= PRODUCT LOGIC =================
        function resetFilters() {
            document.getElementById('filter_search').value = '';
            document.getElementById('filter_categoryId').value = '';
            document.getElementById('filter_status').value = '';
            loadProducts();
        }

        function getODataQueryString() {
            let filters = [];
            const search = document.getElementById('filter_search')?.value.trim();
            const categoryId = document.getElementById('filter_categoryId')?.value;
            const status = document.getElementById('filter_status')?.value;

            if (search) {
                filters.push(`(contains(tolower(productName), tolower('${search}')) or contains(tolower(productCode), tolower('${search}')))`);
            }
            if (categoryId) {
                filters.push(`categoryId eq ${categoryId}`);
            }
            if (status) {
                filters.push(`status eq ${status}`);
            }

            return filters.length > 0 ? `?$filter=${filters.join(' and ')}` : '';
        }

        function loadProducts() {
            const query = getODataQueryString();
            fetch(`${apiBase}/api/Products${query}`, { headers: getHeaders() })
            .then(res => res.json())
            .then(data => {
                const tbody = document.querySelector('#productsTable tbody');
                tbody.innerHTML = '';
                if(data.length === 0){
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-4">Chưa có sản phẩm nào.</td></tr>`;
                    return;
                }
                data.forEach(p => {
                    let statusBadge = p.status ? '<span class="badge bg-success">Đang bán</span>' : '<span class="badge bg-secondary">Ngừng bán</span>';
                    tbody.innerHTML += `
                        <tr>
                            <td class="ps-4 text-secondary fw-bold">${p.productCode}</td>
                            <td class="fw-bold text-dark">${p.productName}</td>
                            <td>${p.category?.categoryName || ''}</td>
                            <td>${statusBadge}</td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-success me-1" onclick="openUploadModal('${p.productCode}')" title="Đổi ảnh">
                                    <i class="bi bi-image"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-info me-1" onclick="openVariants(${p.productId}, '${p.productName}')" title="Biến thể">
                                    <i class="bi bi-list-check"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-primary me-1" onclick='editProduct(${JSON.stringify(p)})' title="Sửa">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteProduct(${p.productId})" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
            })
            .catch(err => Swal.fire('Lỗi', 'Không thể tải danh sách sản phẩm', 'error'));
        }

        function openProductModal() {
            document.getElementById('productForm').reset();
            document.getElementById('p_id').value = 0;
            if (editorInstance) editorInstance.setData("");
            document.getElementById('productModalTitle').innerText = "Thêm Sản phẩm Mới";
            pModal.show();
        }

        function editProduct(p) {
            document.getElementById('p_id').value = p.productId;
            document.getElementById('p_code').value = p.productCode;
            document.getElementById('p_name').value = p.productName;
            document.getElementById('p_categoryId').value = p.categoryId;
            document.getElementById('p_status').value = p.status ? "true" : "false";
            document.getElementById('p_description').value = p.description || "";
            if (editorInstance) editorInstance.setData(p.description || "");
            document.getElementById('productModalTitle').innerText = "Chỉnh sửa Sản phẩm";
            pModal.show();
        }

        function saveProduct() {
            const form = document.getElementById('productForm');
            if(!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const id = document.getElementById('p_id').value;
            const data = {
                productCode: document.getElementById('p_code').value,
                productName: document.getElementById('p_name').value,
                categoryId: parseInt(document.getElementById('p_categoryId').value),
                status: document.getElementById('p_status').value === "true",
                description: editorInstance ? editorInstance.getData() : document.getElementById('p_description').value
            };

            const url = id == 0 ? `${apiBase}/api/Products` : `${apiBase}/api/Products/${id}`;
            const method = id == 0 ? 'POST' : 'PUT';

            fetch(url, {
                method: method,
                headers: getHeaders(),
                body: JSON.stringify(data)
            })
            .then(res => {
                if(!res.ok) throw new Error("Lỗi khi lưu sản phẩm");
                return res.json();
            })
            .then(resData => {
                pModal.hide();
                Swal.fire('Thành công', resData.message || 'Lưu thành công', 'success');
                loadProducts();
            })
            .catch(err => Swal.fire('Lỗi', err.message, 'error'));
        }

        function deleteProduct(id) {
            Swal.fire({
                title: 'Xóa sản phẩm?',
                text: "Toàn bộ biến thể của sản phẩm cũng có thể bị ảnh hưởng. Bạn có chắc không?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`${apiBase}/api/Products/${id}`, {
                        method: 'DELETE',
                        headers: getHeaders()
                    })
                    .then(res => {
                        if(!res.ok) throw new Error("Xóa thất bại");
                        return res.json();
                    })
                    .then(data => {
                        Swal.fire('Đã xóa', data.message, 'success');
                        loadProducts();
                    })
                    .catch(err => Swal.fire('Lỗi', err.message, 'error'));
                }
            })
        }

        // ================= UPLOAD IMAGE LOGIC =================
        function openUploadModal(productCode) {
            document.getElementById('uploadImageForm').reset();
            document.getElementById('upload_pcode').value = productCode;
            changeImagePreview();
            uploadModal.show();
        }

        function changeImagePreview() {
            const productCode = document.getElementById('upload_pcode').value;
            const idx = document.getElementById('upload_imageIndex') ? document.getElementById('upload_imageIndex').value : 0;
            let suffix = idx == 0 ? '' : `-${idx}`;
            document.getElementById('upload_preview').src = `/images/products/${productCode}${suffix}.jpg?t=${new Date().getTime()}`;
        }

        function previewImage(event) {
            const file = event.target.files[0];
            if (file) {
                document.getElementById('upload_preview').src = URL.createObjectURL(file);
            }
        }

        function submitUploadImage() {
            const form = document.getElementById('uploadImageForm');
            if(!form.checkValidity()) {
                form.classList.add('was-validated');
                return;
            }

            const formData = new FormData();
            formData.append('imageFile', document.getElementById('upload_file').files[0]);
            formData.append('productCode', document.getElementById('upload_pcode').value);
            formData.append('imageIndex', document.getElementById('upload_imageIndex') ? document.getElementById('upload_imageIndex').value : 0);

            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            formData.append('__RequestVerificationToken', token);
            
            fetch('?handler=UploadImage', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    alert('Cập nhật ảnh thành công!');
                    uploadModal.hide();
                    
                    // Automatically update the image in the table without reloading the page
                    // This prevents Visual Studio Browser Link from crashing when wwwroot changes
                    const pcode = document.getElementById('upload_pcode').value;
                    const idx = document.getElementById('upload_imageIndex') ? document.getElementById('upload_imageIndex').value : 0;
                    if(idx == 0) {
                        const img = document.querySelector(`img[alt='${pcode}']`);
                        if(img) {
                            img.src = `/images/products/${pcode}.jpg?t=${new Date().getTime()}`;
                        }
                    }
                } else {
                    alert(data.message || 'Có lỗi xảy ra.');
                }
            })
            .catch(err => alert('Lỗi: ' + err));
        }

        // ================= VARIANT LOGIC =================
        function openVariants(productId, productName) {
            document.getElementById('currentProductIdForVariants').value = productId;
            document.getElementById('variantsModalTitle').innerText = "Cấu hình biến thể - " + productName;
            loadVariants(productId);
            vModal.show();
        }

        function loadVariants(productId) {
            // Lấy danh sách biến thể với OData filter và expand PhysicalProducts để tính tồn kho
            fetch(`${apiBase}/api/ProductVariants?$filter=ProductId eq ${productId}&$expand=PhysicalProducts`, { headers: getHeaders() })
            .then(res => res.json())
            .then(data => {
                const tbody = document.querySelector('#variantsTable tbody');
                tbody.innerHTML = '';
                const variants = data.value || data || [];
                if(variants.length === 0){
                    tbody.innerHTML = `<tr><td colspan="7" class="text-center text-muted py-4">Chưa có biến thể nào.</td></tr>`;
                    return;
                }
                variants.forEach(v => {
                    let cpu = v.cpu || v.CPU || '';
                    let ram = v.ram || v.RAM || '';
                    let ssd = v.ssd || v.SSD || '';
                    let color = v.color || v.Color || '';
                    let price = v.price !== undefined ? v.price : (v.Price || 0);
                    let variantId = v.variantId || v.VariantId;
                    let productId = v.productId || v.ProductId;
                    let phys = v.physicalProducts || v.PhysicalProducts || [];
                    
                    let inStockCount = phys.filter(p => (p.status || p.Status) === 'InStock').length;
                    
                    let normV = {
                        variantId: variantId,
                        productId: productId,
                        cpu: cpu,
                        ram: ram,
                        ssd: ssd,
                        color: color,
                        price: price
                    };

                    tbody.innerHTML += `
                        <tr>
                            <td class="ps-4 fw-bold">${cpu}</td>
                            <td>${ram}</td>
                            <td>${ssd}</td>
                            <td>${color}</td>
                            <td class="text-danger fw-bold">${price.toLocaleString('vi-VN')} đ</td>
                            <td><span class="badge bg-primary">${inStockCount}</span></td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-primary me-1" onclick='editVariant(${JSON.stringify(normV).replace(/'/g, "&apos;")})'>
                                    Sửa
                                </button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteVariant(${variantId}, ${productId})">
                                    Xóa
                                </button>
                            </td>
                        </tr>
                    `;
                });
            })
            .catch(err => {
                console.error("Lỗi khi tải biến thể:", err);
                const tbody = document.querySelector('#variantsTable tbody');
                tbody.innerHTML = `<tr><td colspan="7" class="text-center text-danger py-4">Có lỗi xảy ra khi tải dữ liệu.</td></tr>`;
            });
        }

        function openVariantFormModal() {
            document.getElementById('variantForm').reset();
            document.getElementById('v_id').value = 0;
            document.getElementById('variantFormModalTitle').innerText = "Thêm Cấu hình Mới";
            vfModal.show();
        }

        function editVariant(v) {
            document.getElementById('v_id').value = v.variantId;
            document.getElementById('v_cpu').value = v.cpu || '';
            document.getElementById('v_ram').value = v.ram || '';
            document.getElementById('v_ssd').value = v.ssd || '';
            document.getElementById('v_color').value = v.color || '';
            document.getElementById('v_price').value = v.price;
            document.getElementById('variantFormModalTitle').innerText = "Sửa Cấu hình";
            vfModal.show();
        }

        function saveVariant() {
            const form = document.getElementById('variantForm');
            const priceInput = document.getElementById('v_price');
            
            if(parseFloat(priceInput.value) <= 0 || !priceInput.value) {
                priceInput.classList.add('is-invalid');
                return;
            } else {
                priceInput.classList.remove('is-invalid');
            }

            const id = document.getElementById('v_id').value;
            const productId = document.getElementById('currentProductIdForVariants').value;
            
            const data = {
                productId: parseInt(productId),
                cpu: document.getElementById('v_cpu').value,
                ram: document.getElementById('v_ram').value,
                ssd: document.getElementById('v_ssd').value,
                color: document.getElementById('v_color').value,
                price: parseFloat(priceInput.value)
            };

            const url = id == 0 ? `${apiBase}/api/ProductVariants` : `${apiBase}/api/ProductVariants/${id}`;
            const method = id == 0 ? 'POST' : 'PUT';

            fetch(url, {
                method: method,
                headers: getHeaders(),
                body: JSON.stringify(data)
            })
            .then(res => {
                if(!res.ok) throw new Error("Lỗi khi lưu biến thể");
                return res.json();
            })
            .then(resData => {
                vfModal.hide();
                Swal.fire('Thành công', 'Đã lưu cấu hình', 'success');
                loadVariants(productId); // redraw sub-grid
            })
            .catch(err => Swal.fire('Lỗi', err.message, 'error'));
        }

        function deleteVariant(id, productId) {
            Swal.fire({
                title: 'Xóa biến thể?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch(`${apiBase}/api/ProductVariants/${id}`, {
                        method: 'DELETE',
                        headers: getHeaders()
                    })
                    .then(res => {
                        if(!res.ok) throw new Error("Xóa thất bại");
                        return res.json();
                    })
                    .then(data => {
                        Swal.fire('Đã xóa', 'Xóa cấu hình thành công', 'success');
                        loadVariants(productId);
                    })
                    .catch(err => Swal.fire('Lỗi', err.message, 'error'));
                }
            })
        }
    </script>
}
