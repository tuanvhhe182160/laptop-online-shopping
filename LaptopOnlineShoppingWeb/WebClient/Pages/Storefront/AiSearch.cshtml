@page "/ai-suggest"
@{
    ViewData["Title"] = "Trợ lý AI Tìm Laptop";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-dark text-white p-4 text-center rounded-top-4">
                    <h3 class="mb-0"><i class="bi bi-robot me-2"></i> Trợ lý AI Tìm Laptop</h3>
                    <p class="mb-0 text-white-50 small mt-1">Hãy mô tả nhu cầu bằng ngôn ngữ tự nhiên, AI sẽ chọn máy cho bạn!</p>
                </div>

                <div class="card-body p-4">
                    <form id="ai-search-form" onsubmit="searchByAi(event)">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nhu cầu sử dụng chính của bạn là gì?</label>
                            <textarea id="txt-needs" class="form-control" rows="2" placeholder="VD: Mình học IT năm 1, cần máy code mượt, thỉnh thoảng chơi Valorant..." required></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngân sách tối đa (VNĐ)</label>
                            <div class="input-group">
                                <input type="number" id="txt-budget" class="form-control form-control-lg text-danger fw-bold" placeholder="VD: 25000000" required min="5000000" step="500000" />
                                <span class="input-group-text bg-light">VNĐ</span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Ghi chú thêm (Tùy chọn)</label>
                            <input type="text" id="txt-notes" class="form-control" placeholder="VD: Thích máy nhẹ dưới 1.5kg, màu bạc, viền mỏng..." />
                        </div>

                        <button type="submit" id="btn-submit" class="btn btn-primary w-100 btn-lg fw-bold shadow">
                            <i class="bi bi-magic me-2"></i>TÌM MÁY NGAY
                        </button>
                    </form>
                </div>
            </div>

            <!-- Vùng hiển thị trạng thái Loading -->
            <div id="ai-loading" class="text-center py-5 d-none">
                <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <h5 class="mt-3 text-primary fw-bold">🤖 AI đang phân tích kho hàng...</h5>
                <p class="text-muted small">Đang đối chiếu hàng ngàn cấu hình để tìm máy phù hợp nhất cho bạn.</p>
            </div>

            <!-- Vùng hiển thị Kết quả -->
            <div id="ai-results" class="mt-5">
                <!-- Kết quả sẽ được Javascript render vào đây -->
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // LƯU Ý: Thay URL này bằng đúng cổng chạy WebAPI của bạn (VD: cổng 7136 như bạn từng làm)
        const AI_API_URL = "https://localhost:7136/api/AiSearch/suggest";

        // [MỚI THÊM] BƯỚC 1: Phục hồi dữ liệu ngay khi trang vừa tải xong
        document.addEventListener("DOMContentLoaded", () => {
            const savedResults = sessionStorage.getItem("aiResults");
            const savedForm = sessionStorage.getItem("aiForm");

            // Nếu trong bộ nhớ tạm có dữ liệu -> Đổ lại vào Form và vẽ lại HTML
            if (savedResults && savedForm) {
                const formObj = JSON.parse(savedForm);
                document.getElementById("txt-needs").value = formObj.needs;
                document.getElementById("txt-budget").value = formObj.maxBudget;
                document.getElementById("txt-notes").value = formObj.additionalNotes;

                renderResults(JSON.parse(savedResults));
            }
        });

        async function searchByAi(e) {
            e.preventDefault();

            // Lấy các element giao diện
            const btnSubmit = document.getElementById("btn-submit");
            const loadingArea = document.getElementById("ai-loading");
            const resultsArea = document.getElementById("ai-results");

            // Lấy dữ liệu người dùng nhập
            const payload = {
                needs: document.getElementById("txt-needs").value,
                maxBudget: parseFloat(document.getElementById("txt-budget").value),
                additionalNotes: document.getElementById("txt-notes").value
            };

            // [MỚI THÊM] BƯỚC 2: Lưu lại Form mà khách vừa gõ vào bộ nhớ tạm
            sessionStorage.setItem("aiForm", JSON.stringify(payload));

            // Chuyển giao diện sang trạng thái Loading
            btnSubmit.disabled = true;
            resultsArea.innerHTML = "";
            loadingArea.classList.remove("d-none");

            try {
                const res = await fetch(AI_API_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const data = await res.json();

                // Tắt trạng thái Loading
                loadingArea.classList.add("d-none");
                btnSubmit.disabled = false;

                if (res.ok) {
                    // [MỚI THÊM] BƯỚC 3: Lưu list kết quả AI trả về vào bộ nhớ tạm
                    sessionStorage.setItem("aiResults", JSON.stringify(data));

                    renderResults(data);
                } else {
                    Swal.fire("Lỗi", data.message || "Hệ thống AI đang bận.", "error");
                }
            } catch (error) {
                loadingArea.classList.add("d-none");
                btnSubmit.disabled = false;
                Swal.fire("Lỗi kết nối", "Không thể kết nối đến máy chủ AI.", "error");
                console.error(error);
            }
        }

        function renderResults(laptops) {
            const resultsArea = document.getElementById("ai-results");
            let html = `<h4 class="mb-4 fw-bold border-bottom pb-2">🎯 Top ${laptops.length} lựa chọn từ AI:</h4>`;

            laptops.forEach((item, index) => {
                // Định dạng tiền tệ VNĐ
                const formattedPrice = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.price);

                html += `
                <div class="card mb-4 shadow-sm border-primary border-opacity-25">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-bold text-dark mb-0">
                                <span class="badge bg-primary rounded-pill me-2">#${index + 1}</span>
                                ${item.productName}
                            </h5>
                            <h5 class="text-danger fw-bold mb-0">${formattedPrice}</h5>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mb-3 mt-3">
                            <span class="badge bg-light text-dark border"><i class="bi bi-cpu me-1"></i> ${item.cpu}</span>
                            <span class="badge bg-light text-dark border"><i class="bi bi-memory me-1"></i> ${item.ram}</span>
                            <span class="badge bg-light text-dark border"><i class="bi bi-device-hdd me-1"></i> ${item.ssd}</span>
                            <span class="badge bg-light text-dark border"><i class="bi bi-palette me-1"></i> ${item.color}</span>
                        </div>

                        <div class="alert alert-success border-0 bg-success bg-opacity-10 mb-0">
                            <strong><i class="bi bi-robot me-1"></i> Lời khuyên từ AI:</strong><br/>
                            <span class="text-dark">${item.aiReason}</span>
                        </div>

                        <div class="mt-3 text-end">
                            <a href="/Storefront/ProductDetail/${item.variantId}" class="btn btn-outline-primary btn-sm fw-bold">
                                Xem chi tiết máy <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>`;
            });

            resultsArea.innerHTML = html;
        }
    </script>
}