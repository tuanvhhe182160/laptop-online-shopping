@page
@model WebClient.Pages.Storefront.CartModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container mt-5">
    <h2>Giỏ hàng của bạn</h2>
    @if (Model.Cart == null || !Model.Cart.Items.Any())
    {
        <div class="alert alert-info">Giỏ hàng hiện đang trống.</div>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Cart.Items)
                {
                    <tr>
                        <td class="fw-bold">@item.LaptopName</td>
                        <td>@item.UnitPrice.ToString("N0") VNĐ</td>
                        <td>
                            <input type="number" class="form-control text-center" style="width: 80px"
                                   value="@item.Quantity"
                                   onchange="updateCart('@item.LaptopId', this.value)" />
                        </td>
                        <td class="text-danger fw-bold">@item.TotalPrice.ToString("N0") VNĐ</td>
                        <td>
                            <button class="btn btn-danger btn-sm" onclick="removeFromCart('@item.LaptopId')">Xóa</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="text-end">
            <h4>Tổng tiền: @Model.Cart.TotalAmount.ToString("N0") VNĐ</h4>
            <a href="/Storefront/Checkout" class="btn btn-primary">Thanh toán ngay</a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/cart.js"></script>
}
