@page "/storefront/order-history"
@model WebClient.Pages.Storefront.OrderHistoryModel
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="container mt-5">
    <h2>Lịch sử mua hàng</h2>
    
    @if (!Model.Orders.Any())
    {
        <div class="alert alert-info">Bạn chưa có đơn hàng nào.</div>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Ngày Đặt</th>
                    <th>Tổng Tiền</th>
                    <th>Phương thức TT</th>
                    <th>Trạng thái TT</th>
                    <th>Trạng thái Đơn</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model.Orders)
                {
                    <tr>
                        <td>#@order.OrderId</td>
                        <td>@order.OrderDate?.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@order.TotalAmount.ToString("N0") VNĐ</td>
                        <td>@order.PaymentMethod</td>
                        <td>@(order.PaymentStatus == true ? "Đã thanh toán" : "Chưa thanh toán")</td>
                        <td><span class="badge bg-secondary">@order.OrderStatus</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
