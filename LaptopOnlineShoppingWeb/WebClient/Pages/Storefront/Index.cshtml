@page
@model WebClient.Pages.Storefront.IndexModel
@{
    ViewData["Title"] = "Cửa hàng Laptop Online";
}

<div class="container py-4">
    <!-- Hero Header Section -->
    <div class="row mb-5 text-center bg-light p-5 rounded-4 shadow-sm border position-relative overflow-hidden" style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">
        <div class="col-12 position-relative">
            <h1 class="display-4 fw-bold text-primary mb-3">Thế Giới Laptop Online</h1>
            <p class="lead text-secondary max-width-600 mx-auto">Trải nghiệm mua sắm Laptop công nghệ cao cấp nhất, chính hãng cùng hàng ngàn ưu đãi hấp dẫn.</p>
        </div>
    </div>

    <!-- Search and Filter Form -->
    <div class="card shadow-sm border mb-4 rounded-3">
        <div class="card-body bg-white p-4">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label for="Search" class="form-label fw-semibold text-muted small">Tìm kiếm sản phẩm</label>
                    <input type="text" class="form-control rounded-pill border-secondary-subtle px-3" asp-for="Search" placeholder="Nhập tên, mã SP hoặc CPU..." />
                </div>
                <div class="col-md-3">
                    <label for="CategoryId" class="form-label fw-semibold text-muted small">Hãng sản xuất</label>
                    <select class="form-select rounded-pill border-secondary-subtle" asp-for="CategoryId">
                        <option value="">-- Tất cả Hãng --</option>
                        @foreach (var cat in Model.Categories)
                        {
                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="MinPrice" class="form-label fw-semibold text-muted small">Giá từ (VND)</label>
                    <input type="number" step="100000" class="form-control rounded-pill border-secondary-subtle" asp-for="MinPrice" placeholder="0" />
                </div>
                <div class="col-md-2">
                    <label for="MaxPrice" class="form-label fw-semibold text-muted small">Đến (VND)</label>
                    <input type="number" step="100000" class="form-control rounded-pill border-secondary-subtle" asp-for="MaxPrice" placeholder="Ví dụ: 30000000" />
                </div>
                <div class="col-md-1 d-flex align-items-end justify-content-end">
                    <button type="submit" class="btn btn-primary rounded-pill w-100 py-2"><i class="bi bi-search"></i> Lọc</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Products Grid -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @if (Model.ProductVariants != null && Model.ProductVariants.Count > 0)
        {
            foreach (var item in Model.ProductVariants)
            {
                var inStockCount = item.PhysicalProducts?.Count(p => p.Status == "InStock") ?? 0;
                
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-3 product-card transition-hover">
                        @if(inStockCount > 0)
                        {
                            <span class="badge bg-success position-absolute m-2 end-0 rounded-pill">Còn @inStockCount</span>
                        }
                        else
                        {
                            <span class="badge bg-danger position-absolute m-2 end-0 rounded-pill">Hết hàng</span>
                        }
                        
                        <a href="/Storefront/ProductDetail/@item.VariantId" class="d-flex align-items-center justify-content-center bg-light rounded-top-3 p-3 position-relative text-decoration-none" style="height: 180px; overflow: hidden;">
                            <i class="bi bi-laptop text-secondary" style="font-size: 5rem;"></i>
                        </a>
                        
                        <div class="card-body d-flex flex-column p-3">
                            <span class="text-uppercase text-muted fw-bold small">@item.Product?.Category?.CategoryName</span>
                            <h5 class="card-title mt-1 text-truncate" title="@item.Product?.ProductName">
                                <a href="/Storefront/ProductDetail/@item.VariantId" class="text-dark fw-bold text-decoration-none">@item.Product?.ProductName</a>
                            </h5>
                            <p class="text-secondary small mb-1">Mã: <span class="badge bg-secondary-subtle text-secondary">@item.Product?.ProductCode</span></p>
                            <p class="text-secondary small mb-2 text-truncate">Cấu hình: @item.Cpu, @item.Ram, @item.Ssd</p>
                            
                            <div class="mt-auto d-flex justify-content-between align-items-center pt-2 border-top">
                                <div>
                                    <span class="text-danger fw-bold fs-5">@item.Price.ToString("N0") <span class="small" style="font-size: 11px;">đ</span></span>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 p-3 pt-0">
                            <div class="row g-2 align-items-center">
                                <div class="col-4">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">SL</span>
                                        <input type="number" min="1" value="1" max="@(inStockCount > 0 ? inStockCount : 1)" class="form-control form-control-sm buy-qty" data-variant-id="@item.VariantId" @(inStockCount == 0 ? "disabled" : "") />
                                    </div>
                                </div>
                                <div class="col-4">
                                    <button class="btn btn-outline-primary btn-sm w-100 rounded-pill btn-add-cart" data-variant-id="@item.VariantId" @(inStockCount == 0 ? "disabled" : "")>
                                        <i class="bi bi-cart-plus"></i> Thêm giỏ
                                    </button>
                                </div>
                                <div class="col-4">
                                    <button class="btn btn-primary btn-sm w-100 rounded-pill text-white btn-buy-now" data-variant-id="@item.VariantId" @(inStockCount == 0 ? "disabled" : "")>
                                        <i class="bi bi-bag-check"></i> Mua ngay
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="text-muted">
                    <i class="bi bi-laptop-fill display-1 text-secondary opacity-25"></i>
                    <h3 class="mt-3">Không tìm thấy sản phẩm nào</h3>
                    <p>Hãy thử điều chỉnh bộ lọc hoặc từ khóa tìm kiếm khác.</p>
                    <a href="/Storefront/Index" class="btn btn-outline-primary rounded-pill px-4 mt-2">Xem tất cả Sản phẩm</a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .product-card {
        transition: transform 0.25s ease-in-out, box-shadow 0.25s ease-in-out;
        border: 1px solid #f0f0f0 !important;
    }
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }
    .transition-hover {
        transition: all 0.25s ease;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            async function initCartCount() {
                try {
                    const count = await getCartCount();
                    $('#cartCount').text(count || 0);
                } catch (e) {}
            }
            initCartCount();

            $('.btn-add-cart').click(async function() {
                var variantId = $(this).data('variant-id');
                var qtyInput = $(`.buy-qty[data-variant-id='${variantId}']`);
                var qty = parseInt(qtyInput.val()) || 1;

                const res = await addToCart(variantId, qty);

                if (res && res.ok) {
                    initCartCount();
                    Swal.fire({ title: 'Đã thêm vào giỏ hàng', icon: 'success', timer: 1500, showConfirmButton: false });
                } else {
                    if (res && res.message === 'NOT_AUTHENTICATED') {
                        Swal.fire({
                            title: 'Vui lòng đăng nhập',
                            text: 'Bạn cần đăng nhập để thêm sản phẩm vào giỏ hàng.',
                            icon: 'warning',
                            showCancelButton: true,
                            confirmButtonText: 'Đăng nhập ngay',
                            cancelButtonText: 'Đóng'
                        }).then((result) => {
                            if (result.isConfirmed) window.location.href = `/Auth/CustomerLogin?ReturnUrl=${encodeURIComponent(window.location.pathname + window.location.search)}`;
                        });
                    } else {
                        Swal.fire({ title: 'Lỗi', text: res && res.message ? res.message : 'Không thể thêm vào giỏ hàng', icon: 'error' });
                    }
                }
            });

            $('.btn-buy-now').click(function() {
                var isLoggedIn = @(User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Customer") ? "true" : "false");

                if (!isLoggedIn) {
                    Swal.fire({
                        title: 'Vui lòng đăng nhập',
                        text: 'Bạn cần đăng nhập để tiến hành thanh toán.',
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonText: 'Đăng nhập ngay',
                        cancelButtonText: 'Đóng'
                    }).then((result) => {
                        if (result.isConfirmed) window.location.href = `/Auth/CustomerLogin?ReturnUrl=${encodeURIComponent(window.location.pathname + window.location.search)}`;
                    });
                    return;
                }

                var variantId = $(this).data('variant-id');
                var qtyInput = $(`.buy-qty[data-variant-id='${variantId}']`);
                var qty = parseInt(qtyInput.val()) || 1;

                window.location.href = `/Storefront/Checkout?buynow=true&variantid=${variantId}&qty=${qty}`;
            });
        });
    </script>
}
